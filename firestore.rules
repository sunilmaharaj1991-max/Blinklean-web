rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper: check if user is signed in
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: check if user is an admin by email or role
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email in ['sunilmaharaj1991@gmail.com', 'jeevithgowdasr@gmail.com', 'rohithlakshman1@gmail.com'] ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      );
    }

    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Users profiles
    match /users/{userId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == userId;
    }

    // Partner registrations
    match /partner_registrations/{regId} {
      allow create: if true; // Public enrollment form
      allow read, update, delete: if isAdmin();
    }

    // Scrap bookings
    match /scrap_bookings/{bookingId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn() && (resource == null || resource.data.userId == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Green Club registrations
    match /green_club_registrations/{regId} {
      allow create: if true; // Public event registration form
      allow read, update, delete: if isAdmin();
    }

    // Green Club events
    match /green_club_events/{eventId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }

    // Green Club blogs
    match /green_club_blogs/{blogId} {
      allow read: if true; // Publicly viewable
      allow write: if isAdmin();
    }
  }
}
